{
  "acp.agents": {
    "DeepAgent-ACP": {
      "command": "/absolute/path/to/your/python",
      "args": [
        "${workspaceFolder}/scripts/run_deepagent_acp.py"
      ],
      "env": {
        "DEEPAGENT_MODEL": "gemini-2.5-flash"
      }
    }
  },
  "acp.defaultWorkingDirectory": "",
  "acp.logTraffic": true,
  "python.defaultInterpreterPath": "/absolute/path/to/your/python",
  "python-envs.defaultEnvManager": "ms-python.python:conda",
  "python-envs.defaultPackageManager": "ms-python.python:conda"
}
